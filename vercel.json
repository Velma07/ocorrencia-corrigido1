{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/", "dest": "/frontend/index.html" },
    { "src": "/(.*\\.(js|css|png|jpg|jpeg|svg|ico|html))$", "dest": "/frontend/$1" },
    { "src": "/(auth|alunos|professores|turmas|disciplinas|ocorrencias|usuarios)(.*)", "dest": "/api/index.js" }
  ]
}
