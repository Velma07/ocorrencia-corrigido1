{
  "version": 2,
  "rewrites": [
    { "source": "/", "destination": "/frontend/index.html" },
    { "source": "/auth/:path*", "destination": "/api/index.js" },
    { "source": "/alunos/:path*", "destination": "/api/index.js" },
    { "source": "/professores/:path*", "destination": "/api/index.js" },
    { "source": "/turmas/:path*", "destination": "/api/index.js" },
    { "source": "/disciplinas/:path*", "destination": "/api/index.js" },
    { "source": "/ocorrencias/:path*", "destination": "/api/index.js" },
    { "source": "/usuarios/:path*", "destination": "/api/index.js" },
    { "source": "/:path*", "destination": "/frontend/:path*" }
  ]
}
